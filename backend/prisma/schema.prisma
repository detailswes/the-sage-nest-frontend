// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  EXPERT
  PARENT
  ADMIN
}

enum ExpertStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum SessionFormat {
  ONLINE
  IN_PERSON
  BOTH
}

enum ServiceFormat {
  ONLINE
  IN_PERSON
}

enum ServiceCluster {
  FOR_MUM
  FOR_BABY
  PACKAGE
  GIFT
}

enum QualificationType {
  LACTATION_CONSULTANT
  BREASTFEEDING_COUNSELLOR
  INFANT_SLEEP_CONSULTANT
  DOULA
  MIDWIFE
  BABY_OSTEOPATH
  PAEDIATRIC_NUTRITIONIST
  EARLY_YEARS_SPECIALIST
  POSTNATAL_PHYSIOTHERAPIST
  PARENTING_COACH
  OTHER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                      Int       @id @default(autoincrement())
  name                    String    @default("Unknown")
  email                   String    @unique
  password_hash           String
  role                    Role      @default(EXPERT)
  created_at              DateTime  @default(now())
  is_verified             Boolean   @default(true) // false only for new EXPERT registrations
  verification_code       String?
  verification_expires_at DateTime?
  reset_token             String?
  reset_token_expires_at  DateTime?

  expert             Expert?
  refreshTokens      RefreshToken[]
  bookings_as_parent Booking[]      @relation("ParentBookings")
}

model RefreshToken {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  user_id    Int
  expires_at DateTime
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Expert {
  id                Int            @id @default(autoincrement())
  user_id           Int            @unique
  bio               String?
  profile_image     String?
  expertise         String?        // legacy free-text field — kept for backward compat
  stripe_account_id String?
  status            ExpertStatus   @default(PENDING)

  // ── New profile fields ──────────────────────────────────────────────────────
  summary           String?        // 1–2 sentence hero description (~150–200 chars)
  position          String?        // professional title e.g. "Lactation Consultant"
  session_format    SessionFormat?
  address_street    String?
  address_city      String?
  address_postcode  String?
  languages         String[]       @default([])
  timezone          String         @default("Europe/Rome")

  user           User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  services       Service[]
  availability   Availability[]
  qualifications Qualification[]
  certifications Certification[]
  insurance      Insurance?
  blockouts      AvailabilityBlock[]
  bookings       Booking[]          @relation("ExpertBookings")
}

model Service {
  id               Int            @id @default(autoincrement())
  expert_id        Int
  title            String
  description      String?
  duration_minutes Int
  price            Decimal        @db.Decimal(10, 2)
  is_active        Boolean        @default(true)
  format           ServiceFormat?
  cluster          ServiceCluster?

  expert   Expert    @relation(fields: [expert_id], references: [id], onDelete: Cascade)
  bookings Booking[]
}

model Qualification {
  id            Int               @id @default(autoincrement())
  expert_id     Int
  type          QualificationType
  custom_name   String?           // required when type = OTHER
  document_url  String?           // uploaded verification document
  created_at    DateTime          @default(now())

  expert Expert @relation(fields: [expert_id], references: [id], onDelete: Cascade)
}

model Certification {
  id           Int      @id @default(autoincrement())
  expert_id    Int
  name         String
  document_url String?
  created_at   DateTime @default(now())

  expert Expert @relation(fields: [expert_id], references: [id], onDelete: Cascade)
}

model Insurance {
  id                Int      @id @default(autoincrement())
  expert_id         Int      @unique  // one insurance record per expert
  document_url      String
  policy_expires_at DateTime
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  expert Expert @relation(fields: [expert_id], references: [id], onDelete: Cascade)
}

model Availability {
  id          Int    @id @default(autoincrement())
  expert_id   Int
  day_of_week Int    // 0 = Sunday, 6 = Saturday
  start_time  String // e.g. "09:00"
  end_time    String // e.g. "17:00"

  expert Expert @relation(fields: [expert_id], references: [id], onDelete: Cascade)
}

// One-off date overrides — never modifies the recurring Availability schedule
model AvailabilityBlock {
  id         Int      @id @default(autoincrement())
  expert_id  Int
  date       DateTime @db.Date  // specific calendar date only
  start_time String?            // null = full-day block
  end_time   String?            // null = full-day block; both required if one is set
  created_at DateTime @default(now())

  expert Expert @relation(fields: [expert_id], references: [id], onDelete: Cascade)
}

model Booking {
  id                Int           @id @default(autoincrement())
  expert_id         Int
  parent_id         Int
  service_id        Int
  scheduled_at      DateTime      // stored in UTC
  duration_minutes  Int
  format            ServiceFormat
  status            BookingStatus @default(CONFIRMED)
  session_link_sent Boolean       @default(false)
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  expert  Expert  @relation("ExpertBookings", fields: [expert_id], references: [id], onDelete: Cascade)
  parent  User    @relation("ParentBookings", fields: [parent_id], references: [id], onDelete: Cascade)
  service Service @relation(fields: [service_id], references: [id], onDelete: Cascade)
}

